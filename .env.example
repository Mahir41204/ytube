# ── Copy this to .env and fill in your keys ───────────────────────────────

# Google Gemini — FREE, no credit card needed
# Get key at: https://aistudio.google.com/app/apikey (takes 30 seconds)
GEMINI_API_KEY=AIza...

# Pexels — FREE stock footage, instant approval
# Get key at: https://www.pexels.com/api/
PEXELS_API_KEY=...

# YouTube Data API — FREE (6 uploads/day on free quota)
# Step 1: https://console.cloud.google.com → New project
# Step 2: Enable "YouTube Data API v3"
# Step 3: Create OAuth2 credentials → Desktop App
# Step 4: Run `python youtube_auth.py` once to get your refresh token
YOUTUBE_CLIENT_ID=...apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-...
YOUTUBE_REFRESH_TOKEN=1//...

# Airtable — FREE tier is more than enough
# Get Personal Access Token at: https://airtable.com/create/tokens
# (scopes needed: data.records:read, data.records:write, schema.bases:read)
# AIRTABLE_BASE_ID is the "app..." ID — fill this in after the base is created
AIRTABLE_API_TOKEN=pat...
AIRTABLE_BASE_ID=app...

# ── Optional ──────────────────────────────────────────────────────────────
# gTTS accent: com=US | co.uk=British | com.au=Australian | co.in=Indian
GTTS_TLD=com

# Webhook secret for n8n → pipeline calls (set any random string)
WEBHOOK_SECRET=my-secret-key-here
